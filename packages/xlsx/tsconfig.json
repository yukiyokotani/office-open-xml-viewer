{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@silurus/ooxml-core": ["../core/src/index.ts"],
      "@silurus/ooxml-core/*": ["../core/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.stories.ts", "src/**/*.stories.tsx"],
  "references": [{ "path": "../core" }]
}

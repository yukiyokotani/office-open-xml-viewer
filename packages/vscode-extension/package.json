{
  "name": "office-open-xml-viewer",
  "displayName": "Office Viewer — XLSX, DOCX, PPTX",
  "description": "High-fidelity viewer for Office files (.xlsx / .docx / .pptx). Local-only — files never leave your machine. Powered by a Rust/WASM parser and Canvas renderer.",
  "version": "0.14.1",
  "publisher": "silurus",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "ooxml",
    "xlsx",
    "docx",
    "pptx",
    "office",
    "viewer",
    "excel",
    "word",
    "powerpoint"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yukiyokotani/office-open-xml-viewer"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "ooxmlViewer.xlsxEditor",
        "displayName": "OOXML Viewer (XLSX)",
        "selector": [
          { "filenamePattern": "*.xlsx" }
        ],
        "priority": "default"
      },
      {
        "viewType": "ooxmlViewer.docxEditor",
        "displayName": "OOXML Viewer (DOCX)",
        "selector": [
          { "filenamePattern": "*.docx" }
        ],
        "priority": "default"
      },
      {
        "viewType": "ooxmlViewer.pptxEditor",
        "displayName": "OOXML Viewer (PPTX)",
        "selector": [
          { "filenamePattern": "*.pptx" }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "ooxmlViewer.copySelection",
        "title": "Copy Selection",
        "category": "OOXML Viewer"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "node esbuild.config.mjs --production",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@silurus/ooxml-pptx": "workspace:*",
    "@silurus/ooxml-docx": "workspace:*",
    "@silurus/ooxml-xlsx": "workspace:*"
  }
}

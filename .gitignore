.DS_Store
**/.DS_Store
# Office files are not redistributable
*.pptx
*.xlsx
*.docx
# Committable demo samples (free-license files provided by maintainer)
!packages/pptx/public/demo/
!packages/pptx/public/demo/*.pptx
!packages/xlsx/public/demo/
!packages/xlsx/public/demo/*.xlsx
!packages/docx/public/demo/
!packages/docx/public/demo/*.docx
# Office Open XML spec documents
spec/
node_modules/
.claude/
dist/
# WASM build output (regenerate with: npm run wasm)
packages/pptx/src/wasm/
packages/pptx/parser/pkg/
packages/xlsx/src/wasm/
# Rust build artifacts
target/
packages/xlsx/parser/target/
# Storybook build
storybook-static/
# Log files
*.log
# Visual regression test output (generated; not committed)
packages/pptx/tests/visual/screenshots/
packages/pptx/tests/visual/diffs/
packages/pptx/tests/visual/report/
# Playwright
playwright-report/
test-results/
# Reference screenshots (not redistributable — private samples only)
packages/pptx/tests/visual/references/private/
# Local-only Storybook stories that load sample files
packages/pptx/src/*.privateDemo.stories.ts
packages/xlsx/src/*.privateDemo.stories.ts
packages/docx/src/*.privateDemo.stories.ts
# TypeScript build info
*.tsbuildinfo
# npm lockfile (using pnpm)
package-lock.json
# Per-session scratch notes (keep local, do not commit)
**/SESSION_LOG_*.md
**/PLAN_*.md

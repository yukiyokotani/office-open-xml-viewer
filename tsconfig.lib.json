{
  "extends": "./tsconfig.base.json",
  "include": [
    "src/**/*",
    "packages/core/src/**/*",
    "packages/pptx/src/**/*",
    "packages/xlsx/src/**/*",
    "packages/docx/src/**/*"
  ],
  "compilerOptions": {
    "outDir": "./dist",
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": true,
    "paths": {
      "@silurus/ooxml-core": ["./packages/core/src/index.ts"],
      "@silurus/ooxml-core/*": ["./packages/core/src/*"]
    }
  }
}
